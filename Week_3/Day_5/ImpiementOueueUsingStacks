import java.util.*;

public class QueueUsingStacks {

    public static void main(String[] args) {

        Stack<Integer> input = new Stack<>();
        Stack<Integer> output = new Stack<>();

        input.push(1);
        input.push(2);
        input.push(3);

        if (output.isEmpty()) {
            while (!input.isEmpty()) {
                output.push(input.pop());
            }
        }

        System.out.println(output.pop());
    }
}
